{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Hybrid Review Claim",
  "type": "object",
  "required": [
    "claim_id",
    "claim_text",
    "source",
    "baseline_expected",
    "candidate_expected"
  ],
  "properties": {
    "claim_id": {
      "type": "string",
      "pattern": "^C-[0-9]{3}$"
    },
    "claim_text": {
      "type": "string",
      "minLength": 1
    },
    "source": {
      "type": "string",
      "minLength": 1
    },
    "baseline_expected": {
      "type": "string",
      "minLength": 1
    },
    "candidate_expected": {
      "type": "string",
      "minLength": 1
    },
    "limitations": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "additionalProperties": false
}